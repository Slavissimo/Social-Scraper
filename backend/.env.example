# YouTube Data API v3 key
# Get one free at: https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your project, then create an API key.
# Free quota: 10,000 units/day (1 unit per commentThreads request)
YOUTUBE_API_KEY=your_api_key_here

# Optional: frontend URL for CORS (default: http://localhost:5173)
# FRONTEND_URL=http://localhost:5173
